{
  "json.schemas": [
    {
      "fileMatch": ["io-package.json"],
      "url": "https://raw.githubusercontent.com/ioBroker/ioBroker.js-controller/master/schemas/io-package.json"
    },
    {
      "fileMatch": ["/package.json"],
      "url": "https://json.schemastore.org/package.json"
    },
    {
      "fileMatch": [
        "admin/jsonConfig.json",
        "admin/jsonCustom.json",
        "admin/jsonTab.json"
      ],
      "url": "https://raw.githubusercontent.com/ioBroker/ioBroker.admin/master/packages/jsonConfig/schemas/jsonConfig.json"
    }
  ],
  "json.schemaMappings": {
    "io-package.json": "https://raw.githubusercontent.com/ioBroker/ioBroker.js-controller/master/schemas/io-package.json",
    "admin/jsonConfig.json": "https://raw.githubusercontent.com/ioBroker/ioBroker.admin/master/packages/jsonConfig/schemas/jsonConfig.json"
  }
}
