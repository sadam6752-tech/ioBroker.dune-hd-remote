{
  "i18n": true,
  "type": "panel",
  "items": {
    "_playerHeader": {
      "type": "header",
      "text": "Player",
      "size": 3
    },
    "playerName": {
      "type": "text",
      "label": "Player Name",
      "default": "Dune HD",
      "xs": 12, "sm": 6, "md": 4, "lg": 3, "xl": 3
    },
    "playerIP": {
      "type": "text",
      "label": "Player IP Address",
      "default": "192.168.1.120",
      "xs": 12, "sm": 6, "md": 4, "lg": 3, "xl": 3
    },
    "playerPort": {
      "type": "number",
      "label": "Player Port",
      "default": 80,
      "min": 1,
      "max": 65535,
      "help": "Standard: 80 (Linux), 11080 (Android/ATV)",
      "xs": 12, "sm": 4, "md": 3, "lg": 2, "xl": 2
    },
    "connectionTimeout": {
      "type": "number",
      "label": "Connection Timeout (ms)",
      "default": 5000,
      "min": 1000,
      "max": 30000,
      "xs": 12, "sm": 4, "md": 3, "lg": 2, "xl": 2
    },
    "_pollingHeader": {
      "type": "header",
      "text": "Status Polling",
      "size": 3
    },
    "pollingEnabled": {
      "type": "checkbox",
      "label": "Enable Status Polling",
      "default": true,
      "xs": 12, "sm": 4, "md": 3, "lg": 3, "xl": 3
    },
    "pollingInterval": {
      "type": "number",
      "label": "Polling Interval (seconds)",
      "default": 5,
      "min": 1,
      "max": 300,
      "disabled": "!data.pollingEnabled",
      "xs": 12, "sm": 4, "md": 3, "lg": 2, "xl": 2
    },
    "_divider": {
      "type": "divider",
      "xs": 12
    },
    "_pwaHeader": {
      "type": "header",
      "text": "PWA Remote Control",
      "size": 3
    },
    "enablePwa": {
      "type": "checkbox",
      "label": "Enable PWA Remote Control",
      "default": false,
      "xs": 12, "sm": 6, "md": 4, "lg": 3, "xl": 3
    },
    "pwaBindIp": {
      "type": "ip",
      "listenOnAllPorts": true,
      "label": "Bind IP Address",
      "help": "IP address to bind the PWA server to. Select 0.0.0.0 for all interfaces.",
      "disabled": "!data.enablePwa",
      "xs": 12, "sm": 6, "md": 4, "lg": 3, "xl": 3
    },
    "pwaPort": {
      "type": "number",
      "label": "PWA Server Port",
      "default": 8765,
      "min": 1024,
      "max": 65535,
      "help": "Port for the built-in PWA web remote (default: 8765)",
      "disabled": "!data.enablePwa",
      "xs": 12, "sm": 4, "md": 3, "lg": 2, "xl": 2
    },
    "_divider2": {
      "type": "divider",
      "xs": 12
    },
    "testConnectionButton": {
      "type": "sendTo",
      "label": "Test Connection",
      "command": "testConnection",
      "variant": "contained",
      "color": "primary",
      "xs": 12, "sm": 4, "md": 3, "lg": 2, "xl": 2
    }
  }
}
